        "# ---------------------------\n",
        "# 2. HELPER FUNCTIONS\n",
        "# ---------------------------\n",
        "\n",
        "def clean_group_column(series):\n",
        "    \"\"\"Map raw group labels to 0/1, handling NaN values.\"\"\"\n",
        "    # Map non-NaN values first\n",
        "    cleaned = series.map({k: v for k, v in GROUP_MAP.items() if pd.notna(k)})\n",
        "    # Explicitly fill NaN values if np.nan is in GROUP_MAP\n",
        "    if np.nan in GROUP_MAP:\n",
        "        cleaned = cleaned.fillna(GROUP_MAP[np.nan])\n",
        "    return cleaned\n",
        "\n",
        "def find_otu_columns(df):\n",
        "    \"\"\"Find OTU columns automatically.\"\"\"\n",
        "    otu_cols = [c for c in df.columns if str(c).startswith(OTU_PREFIXES)]\n",
        "    return otu_cols\n",
        "\n",
        "def observed_otus(row):\n",
        "    x = np.array(row, dtype=float)\n",
        "    return np.sum(x > 0)\n",
        "\n",
        "def shannon_index(row):\n",
        "    x = np.array(row, dtype=float)\n",
        "    x = x[x > 0]\n",
        "    if len(x) == 0 or x.sum() == 0:\n",
        "        return np.nan\n",
        "    p = x / x.sum()\n",
        "    return entropy(p)\n",
        "\n",
        "def simpson_index(row):\n",
        "    x = np.array(row, dtype=float)\n",
        "    x = x[x > 0]\n",
        "    if len(x) == 0 or x.sum() == 0:\n",
        "        return np.nan\n",
        "    p = x / x.sum()\n",
        "    return 1 - np.sum(p**2)\n",
        "\n",
        "def chao1_index(row):\n",
        "    x = np.array(row, dtype=float)\n",
        "    x = x[x > 0]\n",
        "    if len(x) == 0:\n",
        "        return np.nan\n",
        "    s_obs = len(x)\n",
        "    f1 = np.sum(x == 1)\n",
        "    f2 = np.sum(x == 2)\n",
        "    if f2 == 0:\n",
        "        return s_obs + (f1 * (f1 - 1)) / 2\n",
        "    return s_obs + (f1**2) / (2 * f2)\n",
        "\n",
        "def safe_mannwhitney(group1, group2):\n",
        "    if len(group1) < 1 or len(group2) < 1:\n",
        "        return np.nan, np.nan\n",
        "    return mannwhitneyu(group1, group2, alternative=\"two-sided\")\n",
        "\n",
        "def safe_ttest(group1, group2):\n",
        "    if len(group1) < 2 or len(group2) < 2:\n",
        "        return np.nan, np.nan\n",
        "    stat, p = ttest_ind(group1, group2, equal_var=False, nan_policy=\"omit\")\n",
        "    return stat, p\n",
        "\n",
        "def safe_anova(*groups):\n",
        "    valid_groups = [g for g in groups if len(g) >= 2]\n",
        "    if len(valid_groups) < 2:\n",
        "        return np.nan, np.nan\n",
        "    stat, p = f_oneway(*valid_groups)\n",
        "    return stat, p\n",
        "\n",
        "def safe_kruskal(*groups):\n",
        "    valid_groups = [g for g in groups if len(g) >= 1]\n",
        "    if len(valid_groups) < 2:\n",
        "        return np.nan, np.nan\n",
        "    stat, p = kruskal(*valid_groups)\n",
        "    return stat, p\n",
        "\n",
        "def summarize_by_group(df, group_col, vars_list):\n",
        "    out = []\n",
        "    for var in vars_list:\n",
        "        if var in df.columns:\n",
        "            tmp = df.groupby(group_col)[var].agg([\"count\", \"mean\", \"median\", \"std\", \"min\", \"max\"])\n",
        "            tmp[\"variable\"] = var\n",
        "            out.append(tmp.reset_index())\n",
        "    if out:\n",
        "        return pd.concat(out, ignore_index=True)\n",
        "    return pd.DataFrame()\n",
        "\n",
